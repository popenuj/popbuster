#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 4 ]]; then
  echo "Usage: scripts/cut-clip INPUT START DURATION OUTPUT" >&2
  echo "Example: scripts/cut-clip captures/vhs_01.mkv 00:12:15 00:02:30 assets/videos/home_videos/1995/christmas/papa_betty_buddy.mp4" >&2
  exit 2
fi

input="$1"
start="$2"
duration="$3"
output="$4"
output_dir="$(dirname "${output}")"
tmp_output="$(mktemp "${TMPDIR:-/tmp}/popbuster-clip.XXXXXX.mp4")"

mkdir -p "${output_dir}"

ffmpeg -y \
  -ss "${start}" \
  -i "${input}" \
  -t "${duration}" \
  -vf "scale=800:-2:flags=lanczos,pad=800:480:(ow-iw)/2:(oh-ih)/2:black,setsar=1" \
  -r 30 \
  -c:v libx264 \
  -profile:v main \
  -level 3.1 \
  -pix_fmt yuv420p \
  -preset slow \
  -crf 22 \
  -movflags +faststart \
  -c:a aac \
  -b:a 128k \
  "${tmp_output}"

mv "${tmp_output}" "${output}"
