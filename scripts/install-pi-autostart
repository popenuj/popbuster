#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="${POPBUSTER_PROJECT_ROOT:-${HOME}/popbuster}"
UNIT_NAME="popbuster.service"
UNIT_SOURCE="${PROJECT_ROOT}/support/systemd/${UNIT_NAME}"
UNIT_DIR="${HOME}/.config/systemd/user"
UNIT_TARGET="${UNIT_DIR}/${UNIT_NAME}"

if [[ ! -f "${UNIT_SOURCE}" ]]; then
  echo "Missing service file: ${UNIT_SOURCE}" >&2
  echo "Run this script from a deployed Popbuster checkout on the Pi." >&2
  exit 1
fi

mkdir -p "${UNIT_DIR}"
cp "${UNIT_SOURCE}" "${UNIT_TARGET}"

systemctl --user daemon-reload
systemctl --user enable "${UNIT_NAME}"

cat <<EOF
Installed ${UNIT_TARGET}

Popbuster will start automatically the next time the Pi logs into the desktop.

Useful commands:
  systemctl --user start ${UNIT_NAME}
  systemctl --user stop ${UNIT_NAME}
  systemctl --user restart ${UNIT_NAME}
  systemctl --user status ${UNIT_NAME}
  journalctl --user -u ${UNIT_NAME} -f
  systemctl --user disable ${UNIT_NAME}
EOF
