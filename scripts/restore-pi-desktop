#!/usr/bin/env bash
set -euo pipefail

WAYLAND_SESSION_TARGET="/usr/share/wayland-sessions/popbuster-kiosk.desktop"
X_SESSION_TARGET="/usr/share/xsessions/popbuster-kiosk.desktop"
LIGHTDM_CONF="/etc/lightdm/lightdm.conf.d/90-popbuster-kiosk.conf"

sudo rm -f "${LIGHTDM_CONF}"
sudo rm -f "${WAYLAND_SESSION_TARGET}"
sudo rm -f "${X_SESSION_TARGET}"

cat <<EOF
Removed Popbuster kiosk session configuration.

Reboot to return to the normal desktop session:
  sudo reboot

To return to desktop autostart mode after reboot:
  cd ~/popbuster
  scripts/install-pi-autostart
EOF
