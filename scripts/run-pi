#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="${POPBUSTER_PROJECT_ROOT:-${HOME}/popbuster}"
WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/1000}"
POPBUSTER_FULLSCREEN="${POPBUSTER_FULLSCREEN:-1}"
POPBUSTER_SINGLE_DISPLAY="${POPBUSTER_SINGLE_DISPLAY:-1}"

cd "${PROJECT_ROOT}"
source .venv/bin/activate

export WAYLAND_DISPLAY
export XDG_RUNTIME_DIR

args=()
if [[ "${POPBUSTER_SINGLE_DISPLAY}" == "1" ]]; then
  args+=(--single-display)
fi
if [[ "${POPBUSTER_FULLSCREEN}" == "1" ]]; then
  args+=(--fullscreen)
fi

python -m popbuster "${args[@]}" "$@"
