#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
  echo "Usage: scripts/transcode-video INPUT OUTPUT" >&2
  exit 2
fi

input="$1"
output="$2"
output_dir="$(dirname "${output}")"
tmp_base="$(mktemp "${TMPDIR:-/tmp}/popbuster-video.XXXXXX")"
tmp_output="${tmp_base}.mp4"
rm -f "${tmp_base}"
trap 'rm -f "${tmp_output}"' EXIT

mkdir -p "${output_dir}"

ffmpeg -y -i "${input}" \
  -vf "scale=800:480:force_original_aspect_ratio=decrease:flags=lanczos,pad=800:480:(ow-iw)/2:(oh-ih)/2:black,setsar=1" \
  -r 30 \
  -c:v libx264 \
  -profile:v main \
  -level 3.1 \
  -pix_fmt yuv420p \
  -preset slow \
  -crf 22 \
  -movflags +faststart \
  -c:a aac \
  -b:a 128k \
  "${tmp_output}"

mv "${tmp_output}" "${output}"
trap - EXIT
