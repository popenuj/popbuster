Window.SetBackgroundTopColor(0, 0, 0);
Window.SetBackgroundBottomColor(0, 0, 0);

splash_image = Image("images/active/frame_001.png");
frame_width = 800;
frame_height = 480;

splash_sprite = Sprite(splash_image);
splash_sprite.SetX((Window.GetWidth() - frame_width) / 2);
splash_sprite.SetY((Window.GetHeight() - frame_height) / 2);
splash_sprite.SetZ(100);
